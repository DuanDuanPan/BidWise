{
  "name": "bidwise",
  "version": "0.1.0",
  "description": "BidWise (标智) — AI-powered desktop application for pre-sales bidding workflow automation",
  "main": "./out/main/index.js",
  "author": "BidWise Team",
  "scripts": {
    "dev": "pnpm native:rebuild:electron && electron-vite dev",
    "build": "pnpm native:rebuild:electron && electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:structure": "node scripts/verify-structure.mjs",
    "setup:ai-config": "electron ./scripts/setup-ai-config.mjs",
    "native:rebuild:node": "NODE_OPTIONS=\"--disable-warning=DEP0176\" pnpm rebuild better-sqlite3",
    "native:rebuild:electron": "pnpm exec electron-rebuild -f -w better-sqlite3",
    "python:setup": "bash scripts/python-setup.sh",
    "test:unit": "pnpm native:rebuild:node && vitest run --project main --project renderer",
    "test:integration": "pnpm native:rebuild:node && pnpm python:setup && vitest run --project integration",
    "test:e2e:prepare": "pnpm build && pnpm python:setup",
    "test:e2e:smoke": "pnpm test:e2e:prepare && playwright test -g @smoke",
    "test:e2e": "pnpm test:e2e:prepare && playwright test",
    "test:e2e:headed": "pnpm test:e2e:prepare && playwright test --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:python": "cd python && .venv/bin/pytest",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "test:cold-start": "node scripts/cold-start-check.mjs",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && pnpm python:setup && electron-builder --dir",
    "build:win": "pnpm build && pnpm python:setup && electron-builder --win",
    "build:mac": "pnpm build && pnpm python:setup && electron-builder --mac",
    "build:linux": "pnpm build && pnpm python:setup && electron-builder --linux",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^5.6.1",
    "@anthropic-ai/sdk": "^0.80.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/code-block": "^52.0.11",
    "@platejs/list-classic": "^52.0.11",
    "@platejs/markdown": "^52.3.5",
    "@platejs/table": "^52.0.11",
    "antd": "5.29.3",
    "better-sqlite3": "^12.8.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.3.3",
    "fast-xml-parser": "^5.5.12",
    "fuse.js": "^7.1.0",
    "jsdom": "^26.1.0",
    "kysely": "^0.28.13",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "platejs": "^52.3.4",
    "react-router-dom": "^7.13.1",
    "sharp": "^0.33.5",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier --check"
    ],
    "*.{css,json,md}": [
      "prettier --check"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "sharp"
    ]
  }
}
