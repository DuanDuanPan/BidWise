tFamily": "JetBrains Mono", "fontSize": 10, "fontWeight": "normal", "id": "RBlGL", "type": "text"}], "cornerRadius": 8, "fill": "#FAFAFA", "gap": 8, "id": "j4v5t", "layout": "vertical", "padding": [16, 20], "type": "frame"}, {"alignItems": "center", "children": [{"fill": "#8C8C8C", "height": 20, "iconFontFamily": "lucide", "iconFontName": "brain", "id": "gOxuC", "type": "icon_font", "width": 20}, {"content": "AI 推理", "fill": "#1F1F1F", "fontFamily": "Inter", "fontSize": 12, "fontWeight": "normal", "id": "mZVUl", "type": "text"}, {"content": "SourceAiIcon", "fill": "#8C8C8C", "fontFamily": "JetBrains Mono", "fontSize": 10, "fontWeight": "normal", "id": "58dtV", "type": "text"}], "cornerRadius": 8, "fill": "#FAFAFA", "gap": 8, "id": "n8x62", "layout": "vertical", "padding": [16, 20], "type": "frame"}], "gap": 20, "id": "Tg18y", "type": "frame"}], "gap": 16, "id": "bR5Ma", "layout": "vertical", "name": "Crossfire & Source Icons", "type": "frame", "width": "fill_container"}], "cornerRadius": 8, "fill": "#FFFFFF", "gap": 32, "id": "oqdEG", "layout": "vertical", "name": "Story 1.4 — 自定义图标集", "padding": 48, "type": "frame", "width": 900, "x": 1020, "y": 1100}, {"children": [{"content": "Screen 1 — 编辑器工具栏：文风选择器（默认态）", "fill": "$text-primary", "fontFamily": "PingFang SC", "fontSize": 16, "fontWeight": "600", "id": "arURr", "name": "title1", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "通用文风为默认选中态。选择器位于工具栏右侧，与格式化按钮分隔。", "fill": "$text-secondary", "fontFamily": "PingFang SC", "fontSize": 12, "fontWeight": "normal", "id": "p4W2G", "name": "desc1", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"alignItems": "center", "children": [{"alignItems": "center", "children": [{"alignItems": "center", "children": [{"content": "B", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "700", "id": "Wu5bw", "name": "iconB", "type": "text"}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "77HLu", "justifyContent": "center", "name": "btnB", "type": "frame", "width": 32}, {"alignItems": "center", "children": [{"content": "I", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontStyle": "italic", "fontWeight": "normal", "id": "4O9dn", "name": "iconI", "type": "text"}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "b0jKs", "justifyContent": "center", "name": "btnI", "type": "frame", "width": 32}, {"alignItems": "center", "children": [{"content": "U", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "eg6nK", "name": "iconU", "type": "text"}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "SPM3P", "justifyContent": "center", "name": "btnU", "type": "frame", "width": 32}, {"fill": "$border", "height": 20, "id": "1OTlg", "name": "sep1", "type": "rectangle", "width": 1}, {"alignItems": "center", "children": [{"content": "H1 ▾", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal", "id": "AvUKl", "name": "iconH", "type": "text"}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "91yBE", "justifyContent": "center", "name": "btnH", "padding": [0, 8], "type": "frame"}, {"alignItems": "center", "children": [{"fill": "$text-primary", "height": 16, "iconFontFamily": "lucide", "iconFontName": "list", "id": "x8jqy", "name": "iconList", "type": "icon_font", "width": 16}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "N78N4", "justifyContent": "center", "name": "btnList", "type": "frame", "width": 32}, {"alignItems": "center", "children": [{"fill": "$text-primary", "height": 16, "iconFontFamily": "lucide", "iconFontName": "link", "id": "I8CtM", "name": "iconLink", "type": "icon_font", "width": 16}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "YA5Rp", "justifyContent": "center", "name": "btnLink", "type": "frame", "width": 32}, {"alignItems": "center", "children": [{"fill": "$text-primary", "height": 16, "iconFontFamily": "lucide", "iconFontName": "code", "id": "w1cQ4", "name": "iconCode", "type": "icon_font", "width": 16}], "cornerRadius": 4, "fill": "#00000000", "height": 32, "id": "uq92V", "justifyContent": "center", "name": "btnCode", "type": "frame", "width": 32}], "gap": 4, "id": "S4FIu", "name": "ToolbarLeft", "type": "frame"}, {"alignItems": "center", "children": [{"fill": "$border", "height": 20, "id": "aoUkq", "name": "sep2", "type": "rectangle", "width": 1}, {"alignItems": "center", "children": [{"fill": "$text-secondary", "height": 14, "iconFontFamily": "lucide", "iconFontName": "pen-line", "id": "tntiD", "name": "editIcon", "type": "icon_font", "width": 14}, {"content": "通用文风", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal", "id": "1v2G4", "name": "styleName", "type": "text"}, {"fill": "$text-secondary", "height": 12, "iconFontFamily": "lucide", "iconFontName": "chevron-down", "id": "aRDn4", "name": "chevron", "type": "icon_font", "width": 12}], "cornerRadius": 4, "fill": "#00000000", "gap": 6, "height": 32, "id": "VIHce", "name": "WritingStyleSelector-Default", "padding": [0, 8], "stroke": {"align": "inside", "fill": "#00000000", "thickness": 0}, "type": "frame"}], "gap": 8, "id": "twzYz", "name": "ToolbarRight", "type": "frame"}], "fill": "$bg-content", "height": 48, "id": "ZwPk8", "justifyContent": "space_between", "name": "EditorToolbar", "padding": [0, 16], "stroke": {"align": "inside", "fill": "$border", "thickness": {"bottom": 1}}, "type": "frame", "width": "fill_container"}, {"children": [{"content": "1. 系统总体设计方案", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 22, "fontWeight": "600", "id": "1Y2YL", "name": "h1", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "1.1 系统架构设计", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 18, "fontWeight": "600", "id": "Qu77n", "name": "h2", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "本系统采用微服务架构体系，基于容器化部署方案实现各功能模块的独立部署与弹性扩展。系统整体架构遵循高可用、高可靠、可扩展的设计原则，确保在复杂业务场景下的稳定运行。", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "zwZOQ", "lineHeight": 1.8, "name": "para1", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "系统核心采用分层架构设计，自下而上分为基础设施层、数据服务层、业务逻辑层和应用接口层。各层之间通过标准化接口进行通信，保障系统的松耦合特性。", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "cvjwv", "lineHeight": 1.8, "name": "para2", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "1.2 技术路线论证", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 18, "fontWeight": "600", "id": "TuF1o", "name": "h2b", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "本方案选用的技术路线经过充分论证，综合考虑了系统性能、安全保障能力、运维便捷性等核心指标。关键技术选型均已通过国产化适配验证，满足自主可控要求。", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "GmT4X", "lineHeight": 1.8, "name": "para3", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}], "fill": "$bg-content", "gap": 24, "height": 500, "id": "wvmuL", "layout": "vertical", "name": "EditorContent", "padding": [32, 80], "type": "frame", "width": "fill_container"}, {"alignItems": "center", "children": [{"fill": "$brand", "height": 16, "iconFontFamily": "lucide", "iconFontName": "info", "id": "jmXeb", "name": "calloutIcon", "type": "icon_font", "width": 16}, {"content": "工具栏右侧 WritingStyleSelector 组件。默认选中通用文风，点击展开下拉切换。", "fill": "$brand", "fontFamily": "Inter", "fontSize": 12, "fontWeight": "normal", "id": "C4AVx", "name": "calloutText", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}], "cornerRadius": 4, "fill": "$brand-light", "gap": 8, "id": "sJIQI", "name": "Callout", "padding": [12, 16], "type": "frame", "width": "fill_container"}], "cornerRadius": 8, "fill": "$bg-global", "id": "POdmq", "layout": "vertical", "name": "Scre