y": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "I14ZJ", "lineHeight": 1.8, "name": "p1s3", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"content": "系统核心采用分层架构设计，自下而上分为基础设施层、数据服务层、业务逻辑层和应用接口层。各层之间通过标准化接口进行通信，保障系统的松耦合特性。", "fill": "$text-primary", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "normal", "id": "0ZTuN", "lineHeight": 1.8, "name": "p2s3", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}], "fill": "$bg-content", "gap": 24, "height": 420, "id": "X7Xun", "layout": "vertical", "name": "EditorContent3", "padding": [32, 80], "type": "frame", "width": "fill_container"}, {"alignItems": "center", "children": [{"fill": "$brand", "height": 16, "iconFontFamily": "lucide", "iconFontName": "info", "id": "VfdZ5", "name": "c3Icon", "type": "icon_font", "width": 16}, {"content": "选择器更新为军工文风，Toast 提示用户新文风将在下次生成章节时生效。已有章节内容不变。", "fill": "$brand", "fontFamily": "Inter", "fontSize": 12, "fontWeight": "normal", "id": "IilCW", "name": "c3Text", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}], "cornerRadius": 4, "fill": "$brand-light", "gap": 8, "id": "OsPDW", "name": "Callout3", "padding": [12, 16], "type": "frame", "width": "fill_container"}], "cornerRadius": 8, "fill": "$bg-global", "id": "6LY56", "layout": "vertical", "name": "Screen 3 — 文风切换 Toast 反馈", "padding": 24, "type": "frame", "width": 1200, "x": 0, "y": 3500}], "variables": {"annotation-ai": {"type": "color", "value": "#1677FF"}, "annotation-asset": {"type": "color", "value": "#52C41A"}, "annotation-attack": {"type": "color", "value": "#FF4D4F"}, "annotation-human": {"type": "color", "value": "#722ED1"}, "annotation-score": {"type": "color", "value": "#FAAD14"}, "bg-content": {"type": "color", "value": "#FFFFFF"}, "bg-global": {"type": "color", "value": "#FAFAFA"}, "bg-sidebar": {"type": "color", "value": "#F5F5F5"}, "border": {"type": "color", "value": "#E8E8E8"}, "brand": {"type": "color", "value": "#1677FF"}, "brand-li