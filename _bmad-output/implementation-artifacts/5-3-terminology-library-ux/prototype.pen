{"version": "2.9", "children": [{"children": [{"content": "BidWise 设计系统 — 色彩系统", "fill": "#1F1F1F", "fontFamily": "PingFang SC", "fontSize": 24, "fontWeight": "600", "id": "DU44z", "type": "text"}, {"content": "专业克制的底色，功能色彩为信号。成功/警告/错误不同色，批注五色编码直观映射类型，确保信息层次感和核心交互连贯。", "fill": "#8C8C8C", "fontFamily": "PingFang SC", "fontSize": 13, "fontWeight": "normal", "id": "21izl", "lineHeight": 1.6, "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"children": [{"content": "品牌色 Brand Colors", "fill": "#1F1F1F", "fontFamily": "PingFang SC", "fontSize": 16, "fontWeight": "600", "id": "HjgvQ", "type": "text"}, {"children": [{"children": [{"cornerRadius": 8, "fill": "#1677FF", "height": 56, "id": "Meogm", "type": "rectangle", "width": 80}, {"content": "品牌主色 Primary", "fill": "#1F1F1F", "fontFamily": "PingFang SC", "fontSize": 12, "fontWeight": "normal", "id": "Lz0Mg", "type": "text"}, {"content": "#1677FF", "fill": "#8C8C8C", "fontFamily": "JetBrains Mono", "fontSize": 11, "fontWeight": "normal", "id": "eDx4E", "type": "text"}], "gap": 8, "id": "bbYNH", "layout": "vertical", "type": "frame"}, {"children": [{"cornerRadius": 8, "fill": "#F0F5FF", "height": 56, "id": "pYdfq", "stroke": {"align": "inside", "fill": "#E8E8E8", "thickness": 1}, "type": "rectangle", "width": 80}, {"content": "品牌辅色 Light", "fill": "#1F1F1F", "fontFamily": "PingFang SC", "fontSize": 12, "fontWeight": "normal", "id": "0azOO", "type": "text"}, {"content": "#F0F5FF", "fill": "#8C8C8C", "fontFamily": "JetBrains Mono", "fontSize": 11, "fontWeight": "normal", "id": "v5KT0", "type": "text"}], "gap": 8, "id": "S7UXr", "layout": "vertical", "type": "frame"}], "gap": 24, "id": "CrMFv", "type": "frame"}], "gap": 16, "id": "crzXh", "layout": "vertical", "name": "Brand Colors", "type": "frame", "width": "fill_container"}, {"children": [{"content": "语义色 Semantic Colors", "fill": "#1F1F1F", "fontFamily": "PingFang SC", "fontSize": 16, "fontWeight": "600", "id": "dPQQM", "type": "text"}, {"children"