 24, "id": "vx5vF", "justifyContent": "center", "layout": "vertical", "name": "closeBtn", "type": "frame", "width": 24}], "height": 56, "id": "Cq4AE", "name": "ModalHeader", "padding": [0, 24], "stroke": {"align": "inside", "fill": "#F0F0F0", "thickness": {"bottom": 1}}, "type": "frame", "width": "fill_container"}, {"children": [{"content": "粘贴会议纪要、邮件、沟通记录等文本内容，或上传 .txt 文件", "fill": "#71717A", "fontFamily": "Inter", "fontSize": 13, "id": "TRdUP", "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}, {"children": [{"content": "3月15日客户沟通会议纪要 参会人: 张总(客户方IT负责人)、王工(客户方运维主管) 1. 张总反复强调绝对不能再出现上次系统宕机的情况,提到去年因系统故障导致全线停产4小时,被集团通报批评。 2. 王工私下提到他们团队运维能力有限,希望系统能傻瓜式运维,最好有自动告警和一键恢复功能。 3. 张总对竞对A公司的方案表示不满,暗示对实施团队稳定性非常看重。 4. 会后闲聊时张总提到今年集团对数字化转型有KPI考核,这个项目是他今年最重要的工作。", "fill": "#595959", "fontFamily": "Inter", "fontSize": 13, "id": "sEozY", "lineHeight": 1.7, "textGrowth": "fixed-width", "type": "text", "width": "fill_container"}], "clip": true, "cornerRadius": 6, "fill": "#FFFFFF", "height": 220, "id": "v9wFl", "layout": "vertical", "name": "TextArea", "padding": 12, "stroke": {"align": "inside", "fill": "#D9D9D9", "thickness": 1}, "type": "frame", "width": "fill_container"}, {"alignItems": "center", "children": [{"fill": "#A1A1AA", "height": 16, "iconFontFamily": "lucide", "iconFontName": "upload", "id": "ugN1o", "type": "icon_font", "width": 16}, {"content": "点击或拖拽上传 .txt 文件", "fill": "#A1A1AA", "fontFamily": "Inter", "fontSize": 13, "id": "t3muy", "type": "text"}], "cornerRadius": 6, "fill": "#FAFAFA", "gap": 8, "height": 40, "id": "0htus", "justifyContent": "center", "name": "UploadZone", "stroke": {"align": "inside", "fill": "#D9D9D9", "thickness": 1}, "type": "frame", "width": "fill_container"}], "gap": 16, "id": "PHRzi", "layout": "vertical", "name": "ModalBody", "padding": 24, "type": "frame", "width": "fill_container"}, {"alignItems": "center", "children": [{"alignItems": "center", "children": [{"content": "取消", "fill": "#595959", "fontFamily": "Inter", "fon